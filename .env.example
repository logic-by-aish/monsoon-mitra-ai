# Copy to .env for local dev:  cp .env.example .env   (never commit the real .env)

# ---- App ----
APP_NAME="MonsoonMitra.ai"
ALLOWED_ORIGINS=*
# Set false ONLY for quick local testing without Firebase. MUST be true in prod.
AUTH_REQUIRED=true

# ---- Gemini (Developer API key path; key comes from Secret Manager in prod) ----
GEMINI_MODEL=gemini-3.5-flash
GEMINI_MODEL_FALLBACK=gemini-2.5-flash
USE_VERTEXAI=false
GEMINI_API_KEY=
# If USE_VERTEXAI=true instead (key-less via ADC):
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# ---- Optional extra Google APIs ----
GOOGLE_MAPS_API_KEY=

# ---- Firebase (WEB config — public identifiers, safe to expose) ----
FIREBASE_PROJECT_ID=your-gcp-project-id
FIREBASE_WEB_API_KEY=your-web-api-key
FIREBASE_AUTH_DOMAIN=your-gcp-project-id.firebaseapp.com
FIREBASE_APP_ID=your-web-app-id
